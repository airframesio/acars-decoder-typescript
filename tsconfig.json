{
  "compilerOptions": {
    "target": "esNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "declaration": true,
    "outDir": "./dist",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@airframes/ads-runtime-ts": ["vendor/airframes-decoder/runtimes/typescript/index.ts"],
      "@airframes/ads-runtime-ts/helpers": ["vendor/airframes-decoder/runtimes/typescript/helpers.ts"],
      "@airframes/ads-runtime-ts/escape_hatches": ["vendor/airframes-decoder/runtimes/typescript/escape_hatches/index.ts"]
    }
  },
  "include": ["lib/*.ts", "lib/**/*.ts"],
  "exclude": ["node_modules", "vendor"]
}
